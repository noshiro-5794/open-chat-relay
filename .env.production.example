# Copy this file to .env on the deployment server and replace every placeholder.

OPEN_CHAT_RELAY_ENVIRONMENT=production
OPEN_CHAT_RELAY_DEBUG=false
OPEN_CHAT_RELAY_LOG_LEVEL=INFO
OPEN_CHAT_RELAY_DOCS_ENABLED=false
OPEN_CHAT_RELAY_RUN_MIGRATIONS=true

# Public/container host bindings. Internal container ports remain unchanged.
OPEN_CHAT_RELAY_API_BIND_HOST=0.0.0.0
OPEN_CHAT_RELAY_API_HOST_PORT=18000
OPEN_CHAT_RELAY_CONSOLE_BIND_HOST=0.0.0.0
OPEN_CHAT_RELAY_CONSOLE_HOST_PORT=15173
OPEN_CHAT_RELAY_DEMO_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_DEMO_HOST_PORT=15174
OPEN_CHAT_RELAY_DEMO_API_BASE_URL=https://api.example.com
OPEN_CHAT_RELAY_POSTGRES_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_POSTGRES_HOST_PORT=15432
OPEN_CHAT_RELAY_REDIS_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_REDIS_HOST_PORT=16379
OPEN_CHAT_RELAY_MINIO_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_MINIO_HOST_PORT=19000
OPEN_CHAT_RELAY_MINIO_CONSOLE_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_MINIO_CONSOLE_HOST_PORT=19001
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_TCP_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_TCP_HOST_PORT=18081
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_UDP_BIND_HOST=0.0.0.0
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_UDP_HOST_PORT=18081

# Public URLs seen by browsers and SDKs.
OPEN_CHAT_RELAY_PUBLIC_API_URL=https://api.example.com
OPEN_CHAT_RELAY_CONSOLE_API_BASE_URL=https://api.example.com
OPEN_CHAT_RELAY_CORS_ORIGINS=https://console.example.com,https://app.example.com

# Generate these values with: python3 scripts/generate_deployment_secrets.py
OPEN_CHAT_RELAY_JWT_SECRET_KEY=replace-with-generated-secret
OPEN_CHAT_RELAY_GATEWAY_INTERNAL_TOKEN=replace-with-generated-gateway-token
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_SECRET=replace-with-generated-webtransport-secret

# Core backends. Compose overrides the container-to-container URLs for API services.
OPEN_CHAT_RELAY_POSTGRES_PASSWORD=replace-with-generated-postgres-password
OPEN_CHAT_RELAY_RATE_LIMIT_BACKEND=redis
OPEN_CHAT_RELAY_PRESENCE_BACKEND=redis
OPEN_CHAT_RELAY_TYPING_BACKEND=redis
OPEN_CHAT_RELAY_DATABASE_URL=postgresql+asyncpg://openchatrelay:replace-with-generated-postgres-password@postgres:5432/openchatrelay
OPEN_CHAT_RELAY_REDIS_URL=redis://redis:6379/0

# WebTransport over HTTP/3. Expose both TCP and UDP on the gateway host port.
OPEN_CHAT_RELAY_WEBTRANSPORT_ENABLED=true
OPEN_CHAT_RELAY_WEBTRANSPORT_URL=https://chat.example.com:18081/v1/wt
OPEN_CHAT_RELAY_WEBTRANSPORT_HEALTH_URL=http://webtransport-gateway:8080/ready
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_RUNTIME_ENABLED=true
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_CERT_PATH=/certs/webtransport.crt
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_KEY_PATH=/certs/webtransport.key
OPEN_CHAT_RELAY_WEBTRANSPORT_CERTS_DIR=./local/certs
OPEN_CHAT_RELAY_GATEWAY_MAX_FRAME_BYTES=1048576

# S3-compatible object storage. Replace with external object storage for larger deployments.
OPEN_CHAT_RELAY_STORAGE_BACKEND=s3
OPEN_CHAT_RELAY_S3_ENDPOINT_URL=http://localhost:19000
OPEN_CHAT_RELAY_S3_PUBLIC_ENDPOINT_URL=https://files.example.com
OPEN_CHAT_RELAY_S3_REGION_NAME=us-east-1
OPEN_CHAT_RELAY_S3_ACCESS_KEY_ID=openchatrelay
OPEN_CHAT_RELAY_S3_SECRET_ACCESS_KEY=replace-with-generated-s3-secret
OPEN_CHAT_RELAY_S3_BUCKET=open-chat-relay
OPEN_CHAT_RELAY_VERIFY_ATTACHMENT_UPLOADS=true
