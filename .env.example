OPEN_CHAT_RELAY_ENVIRONMENT=local
OPEN_CHAT_RELAY_DEBUG=true
OPEN_CHAT_RELAY_LOG_LEVEL=INFO
OPEN_CHAT_RELAY_DOCS_ENABLED=true
OPEN_CHAT_RELAY_MAX_REQUEST_BODY_BYTES=1048576
OPEN_CHAT_RELAY_RUN_MIGRATIONS=true

# Host port bindings. Internal container ports stay stable; change these when a host
# already uses the default ports.
OPEN_CHAT_RELAY_API_BIND_HOST=0.0.0.0
OPEN_CHAT_RELAY_API_HOST_PORT=8000
OPEN_CHAT_RELAY_CONSOLE_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_CONSOLE_HOST_PORT=5173
OPEN_CHAT_RELAY_CONSOLE_API_BASE_URL=http://localhost:8000
OPEN_CHAT_RELAY_POSTGRES_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_POSTGRES_HOST_PORT=5432
OPEN_CHAT_RELAY_REDIS_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_REDIS_HOST_PORT=6379
OPEN_CHAT_RELAY_MINIO_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_MINIO_HOST_PORT=9000
OPEN_CHAT_RELAY_MINIO_CONSOLE_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_MINIO_CONSOLE_HOST_PORT=9001
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_TCP_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_TCP_HOST_PORT=8081
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_UDP_BIND_HOST=127.0.0.1
OPEN_CHAT_RELAY_WEBTRANSPORT_GATEWAY_UDP_HOST_PORT=8081
OPEN_CHAT_RELAY_WEBTRANSPORT_CERTS_DIR=./local/certs

OPEN_CHAT_RELAY_RATE_LIMIT_ENABLED=true
OPEN_CHAT_RELAY_RATE_LIMIT_WINDOW_SECONDS=60
OPEN_CHAT_RELAY_RATE_LIMIT_GENERAL_REQUESTS=600
OPEN_CHAT_RELAY_RATE_LIMIT_AUTH_REQUESTS=30
OPEN_CHAT_RELAY_RATE_LIMIT_WEBHOOK_REQUESTS=120
OPEN_CHAT_RELAY_RATE_LIMIT_APP_API_REQUESTS=300
OPEN_CHAT_RELAY_RATE_LIMIT_BACKEND=redis
OPEN_CHAT_RELAY_RATE_LIMIT_REDIS_KEY_PREFIX=open_chat_relay:rate_limit
OPEN_CHAT_RELAY_RATE_LIMIT_FAIL_OPEN=true
OPEN_CHAT_RELAY_OUTBOX_PUBLISHER_ENABLED=true
OPEN_CHAT_RELAY_OUTBOX_PUBLISHER_POLL_INTERVAL_SECONDS=1
OPEN_CHAT_RELAY_OUTBOX_PUBLISHER_BATCH_SIZE=100
OPEN_CHAT_RELAY_OUTBOX_PUBLISHER_MAX_ATTEMPTS=5
OPEN_CHAT_RELAY_OUTBOX_REDIS_CHANNEL_PREFIX=open_chat_relay
OPEN_CHAT_RELAY_PRESENCE_BACKEND=redis
OPEN_CHAT_RELAY_PRESENCE_REDIS_KEY_PREFIX=open_chat_relay:presence
OPEN_CHAT_RELAY_PRESENCE_TTL_SECONDS=120
OPEN_CHAT_RELAY_TYPING_BACKEND=redis
OPEN_CHAT_RELAY_TYPING_REDIS_KEY_PREFIX=open_chat_relay:typing
OPEN_CHAT_RELAY_TYPING_TTL_SECONDS=10

OPEN_CHAT_RELAY_DATABASE_URL=postgresql+asyncpg://openchatrelay:openchatrelay@localhost:5432/openchatrelay
OPEN_CHAT_RELAY_POSTGRES_PASSWORD=openchatrelay
OPEN_CHAT_RELAY_REDIS_URL=redis://localhost:6379/0

OPEN_CHAT_RELAY_JWT_SECRET_KEY=change-this-local-secret-at-least-32-bytes
OPEN_CHAT_RELAY_ACCESS_TOKEN_EXPIRE_MINUTES=15
OPEN_CHAT_RELAY_REFRESH_TOKEN_EXPIRE_DAYS=30
OPEN_CHAT_RELAY_FIRST_USER_SYSTEM_ADMIN=true

OPEN_CHAT_RELAY_WEBTRANSPORT_ENABLED=false
OPEN_CHAT_RELAY_WEBTRANSPORT_URL=https://localhost:8081/v1/wt
OPEN_CHAT_RELAY_WEBTRANSPORT_HEALTH_URL=http://webtransport-gateway:8080/ready
OPEN_CHAT_RELAY_WEBTRANSPORT_HEALTH_TIMEOUT_SECONDS=0.5
OPEN_CHAT_RELAY_GATEWAY_INTERNAL_TOKEN=change-this-local-gateway-token
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_RUNTIME_ENABLED=false
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_CERT_PATH=/certs/webtransport.crt
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_KEY_PATH=/certs/webtransport.key
OPEN_CHAT_RELAY_GATEWAY_WEBTRANSPORT_SECRET=change-this-local-webtransport-secret
OPEN_CHAT_RELAY_GATEWAY_MAX_FRAME_BYTES=1048576

OPEN_CHAT_RELAY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

OPEN_CHAT_RELAY_STORAGE_BACKEND=s3
OPEN_CHAT_RELAY_S3_ENDPOINT_URL=http://localhost:9000
OPEN_CHAT_RELAY_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
OPEN_CHAT_RELAY_S3_REGION_NAME=us-east-1
OPEN_CHAT_RELAY_S3_ACCESS_KEY_ID=openchatrelay
OPEN_CHAT_RELAY_S3_SECRET_ACCESS_KEY=openchatrelay-secret
OPEN_CHAT_RELAY_S3_BUCKET=open-chat-relay
OPEN_CHAT_RELAY_S3_PRESIGNED_UPLOAD_EXPIRE_SECONDS=900
OPEN_CHAT_RELAY_S3_PRESIGNED_DOWNLOAD_EXPIRE_SECONDS=900
OPEN_CHAT_RELAY_VERIFY_ATTACHMENT_UPLOADS=true
